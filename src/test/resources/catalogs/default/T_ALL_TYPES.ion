{
  type: "bag",
  items: {
    type: "struct",
    constraints: [ closed, ordered, unique ],
    fields: [
      // Additional data type columns
      {
        name: "col_bool",
        type: "bool",
      },

      {
        name: "col_int16",
        type: "int16",
      },
      {
        name: "col_int32",
        type: "int32",
      },
      {
        name: "col_int64",
        type: "int64",
      },
      {
        name: "col_float32",
        type: "float32",
      },
      {
        name: "col_float64",
        type: "float64",
      },
      {
        name: "col_decimal",
        type: "decimal",
      },
      {
        name: "col_string",
        type: "string",
      },
      {
        name: "col_char",
        type: {
          type: "char",
          length: 10
        },
      },
      {
        name: "col_date",
        type: "date",
      },
      {
        name: "col_time",
        type: "time",
      },
      {
        name: "col_timez",
        type: "timez",
      },
      {
        name: "col_timestamp",
        type: "timestamp",
      },
      {
        name: "col_timestampz",
        type: "timestampz",
      },
      {
        name: "col_blob",
        type: "blob",
      },
      {
        name: "col_clob",
        type: "clob",
      },
      {
        name: "col_list",
        type: {
          type: "list",
          items: "int32",
        },
      },
      {
        name: "col_bag",
        type: {
          type: "bag",
          items: "string",
        },
      },
      {
        name: "col_struct_simple",
        type: {
          type: "struct",
          constraints: [ closed, ordered, unique ],
          fields: [
            { name: "level1_col_int", type: "int32" },
            { name: "level1_col_double", type: "float64" },
            { name: "level1_col_string", type: "string" },
            { name: "level1_col_timestamp", type: "timestamp" },
          ]
        },
      },
      {
        name: "col_struct_nested",
        type: {
          type: "struct",
          constraints: [ closed, ordered, unique ],
          fields: [
            { name: "level1_col_int", type: "int32" },
            { name: "level1_col_double", type: "float64" },
            { name: "level1_col_string", type: "string" },
            { name: "level1_col_timestamp", type: "timestamp" },
            {
              name: "level1_col_struct",
              type: {
                type: "struct",
                constraints: [ closed, ordered, unique ],
                fields: [
                  { name: "level2_col_int", type: "int32" },
                  { name: "level2_col_double", type: "float64" },
                  { name: "level2_col_string", type: "string" },
                  { name: "level2_col_timestamp", type: "timestamp" },
                ]
              },
            },
          ]
        },
      },
      {
        name: "col_any",
        type: "any",
      },
    ]
  }
}